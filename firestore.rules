rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Events (match state) ────────────────────────────────────
    // Read: any authenticated user
    // Write: only server/admin SDK (no client writes)
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ─── Crowd Zones ─────────────────────────────────────────────
    // Read: any authenticated user
    // Write: only server/admin SDK
    match /crowd_zones/{eventId}/{zone}/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ─── Queue States ────────────────────────────────────────────
    // Read: any authenticated user
    // Write: only server/admin SDK
    match /queue_states/{eventId}/{standId}/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ─── Groups ──────────────────────────────────────────────────
    // Read: only members of the group
    // Write: only members (via server API, but rule enforces membership)
    match /groups/{groupId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.memberUids;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.memberUids;
      allow delete: if false;
    }

    // ─── Attendees ───────────────────────────────────────────────
    // Read/Write: only the owning user
    match /attendees/{uid} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // ─── Nudge Log ───────────────────────────────────────────────
    // Read: only the owning user (or admin SDK)
    // Write: only server/admin SDK
    match /nudge_log/{eventId}/attendees/{uid} {
      allow read: if request.auth != null
                  && request.auth.uid == uid;
      allow write: if false;
    }

    // ─── Banned Users ────────────────────────────────────────────
    // Read/Write: admin only (server SDK)
    match /banned_users/{uid} {
      allow read, write: if false;
    }

    // ─── Default Deny ────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
